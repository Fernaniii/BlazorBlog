@page "/"

<PageTitle>Home</PageTitle>

<!-- Hero Section -->
<section class="py-5 text-center bg-dark border-bottom border-secondary text-light">
    <div class="container-lg">
        <h2 class="display-3 fw-bold mb-3">Clean Architecture</h2>
        <p class="fs-5 text-secondary">Template</p>

        <p class="fs-6 text-secondary mb-4">
            
        </p>

        <div>
            <span class="badge bg-secondary text-dark me-2 mb-2">Blazor Server</span>
            <span class="badge bg-secondary text-dark me-2 mb-2">EF Core</span>
            <span class="badge bg-secondary text-dark me-2 mb-2">.NET 9</span>
            <span class="badge bg-secondary text-dark mb-2">Clean Architecture</span>
        </div>
    </div>
</section>

<!-- Core Features -->
<section class="py-5 bg-light border-bottom">
    <div class="container-lg">
        <div class="text-center mb-5">
            <h2 class="fw-bold">Core Features</h2>
        </div>

        <div class="row g-4 justify-content-center">

            <div class="col-md-6 col-lg-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h5 class="fw-bold">Architecture</h5>
                        <ul class="list-unstyled">
                            <li><i class="text-success bi bi-check2-circle me-2"></i> Clean Architecture</li>
                            <li><i class="text-success bi bi-check2-circle me-2"></i> EF Core</li>
                            <li><i class="text-success bi bi-check2-circle me-2"></i> Repository Pattern</li>
                            <li><i class="text-success bi bi-check2-circle me-2"></i> DRY</li>
                        </ul>
                    </div>
                </div>
            </div>



            <div class="col-md-6 col-lg-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h5 class="fw-bold">Presentation</h5>
                        <ul class="list-unstyled">
                            <li><i class="text-success bi bi-check2-circle me-2"></i> Blazor Server</li>
                            <li><i class="text-success bi bi-check2-circle me-2"></i> Boostrap 5</li>
                            <li><i class="text-success bi bi-check2-circle me-2"></i> JS Runtime Modal</li>
                            <li><i class="text-success bi bi-check2-circle me-2"></i> Interactivity</li>
                        </ul>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h5 class="fw-bold">Testing</h5>
                        <ul class="list-unstyled">
                            <li><i class="text-success bi bi-check2-circle me-2"></i> NUnit</li>
                            <li><i class="text-success bi bi-check2-circle me-2"></i> Integration Tests</li>
                        </ul>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h5 class="fw-bold">Additionals</h5>
                        <ul class="list-unstyled">
                            <li><i class="text-success bi bi-check2-circle me-2"></i> Soft Delete</li>
                            <li><i class="text-danger bi bi-x-circle me-2"></i> Logging</li>
                            <li><i class="text-success bi bi-check2-circle me-2"></i> Audit Trailing</li>
                        </ul>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

<!-- Feature Applications -->
<section class="py-5 bg-dark text-light">
    <div class="container-lg">

        <div class="text-center mb-5">
            <h2 class="fw-bold">Feature Applications</h2>
        </div>

        <div class="row g-4 justify-content-center">

            <!-- Weaher Boiler Plate -->
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card bg-secondary text-light h-100 border-0 shadow-sm">
                    <div class="row g-0 h-100">

                        <div class="col-4 bg-dark d-flex align-items-center justify-content-center rounded-start">
                            <i class="bi bi-clock-history display-5 text-light"></i>
                        </div>

                        <div class="col-8">
                            <div class="card-body d-flex flex-column h-100">
                                <h5 class="fw-bold mb-3">Weather Page</h5>

                                <ul class="list-unstyled mb-3 small">
                                    <li class="mb-1"><i class="bg-success bi bi-check2-circle me-2"></i>rendermode</li>
                                </ul>

                                <div class="mt-auto">
                                    <a href="/weather" class="btn btn-outline-light btn-sm w-100 fw-bold">
                                        Access Weather
                                    </a>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

            <!-- Articles -->
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card bg-secondary text-light h-100 border-0 shadow-sm">
                    <div class="row g-0 h-100">

                        <div class="col-4 bg-dark d-flex align-items-center justify-content-center rounded-start">
                            <i class="bi bi-clock-history display-5 text-light"></i>
                        </div>

                        <div class="col-8">
                            <div class="card-body d-flex flex-column h-100">
                                <h5 class="fw-bold mb-3">Simple Article Page</h5>

                                <ul class="list-unstyled mb-3 small">
                                    <li class="mb-1"><i class="bg-success bi bi-check2-circle me-2"></i>CRUD Operations</li>
                                    <li class="mb-1"><i class="bg-success bi bi-check2-circle me-2"></i>Clean Architecture</li>
                                    <li class="mb-1"><i class="bg-danger bi bi-x-circle me-2"></i>Comments</li>
                                    <li class="mb-1"><i class="bg-danger bi bi-x-circle me-2"></i>Reactions</li>
                                </ul>

                                <div class="mt-auto">
                                    <a href="/articles" class="btn btn-outline-light btn-sm w-100 fw-bold">
                                        Access Article
                                    </a>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

            <!-- Audit Logging -->
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card bg-secondary text-light h-100 border-0 shadow-sm">
                    <div class="row g-0 h-100">

                        <div class="col-4 bg-dark d-flex align-items-center justify-content-center rounded-start">
                            @* Using a dedicated icon can sometimes look cleaner than a favicon *@
                            <i class="bi bi-clock-history display-5 text-light"></i>
                        </div>

                        <div class="col-8">
                            <div class="card-body d-flex flex-column h-100">
                                <h5 class="fw-bold mb-3">Audit Trailing</h5>

                                <ul class="list-unstyled mb-3 small">
                                    <li class="mb-1"><i class="bg-success bi bi-check2-circle me-2"></i>Automated Entity Tracking</li>
                                    <li class="mb-1"><i class="bg-success bi bi-check2-circle me-2"></i>Clean Architecture Pattern</li>
                                    <li class="mb-1"><i class="bg-success bi bi-check2-circle me-2"></i>Historical Data Comparison</li>
                                    <li class="mb-1"><i class="bg-success bi bi-check2-circle me-2"></i>Full System Coverage</li>
                                    <li class="mb-1"><i class="bg-danger bi bi-check2-circle me-2"></i>Excel Export</li>
                                    <li class="mb-1"><i class="bg-danger bi bi-check2-circle me-2"></i>PDF Export</li>
                                </ul>

                                <div class="mt-auto">
                                    <a href="/audit-trailing" class="btn btn-outline-light btn-sm w-100 fw-bold">
                                        Access Logs
                                    </a>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>


        </div>

    </div>
</section>

<!-- Footer -->
<footer class="py-4 bg-dark text-center text-secondary">
    <div class="container">
        <small class="d-block mb-1">© 2026 Blazor Blog - Built with .NET 9</small>
        <small class="d-block">Developer: Magnaye, Fernando Jose</small>
    </div>
</footer>